@startuml
title Диаграмма классов\n"Система прогнозирования цен на авиабилеты"
skinparam classAttributeIconSize 0

class User {
  id: int
  name: str
  email: str
}

class ForecastRequest {
  origin: str
  destination: str
  departure_date: date
  passengers: int
  +validate(): bool
}

class PredictionResult {
  price: float
  created_at: datetime
}

class ForecastController {
  +get_forecast(request): PredictionResult
}

class ForecastService {
  +predict_price(request): PredictionResult
}

class DataProcessor {
  +prepare_data(request)
}

class PriceModel {
  +predict(features): float
}

class HistoryRepository {
  +save(result)
  +get_all(user)
}

User --> ForecastRequest
ForecastController --> ForecastService
ForecastService --> ForecastRequest
ForecastService --> DataProcessor
ForecastService --> PriceModel
ForecastService --> PredictionResult
ForecastService --> HistoryRepository

@enduml