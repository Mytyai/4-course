@startuml
left to right direction
title Диаграмма вариантов использования\n"Система прогнозирования цен на авиабилеты"

actor "Пользователь" as User
actor "Администратор" as Admin

rectangle "Система прогнозирования" {

  usecase "Ввести параметры перелёта" as UC1
  usecase "Получить прогноз цены" as UC2
  usecase "Просмотреть историю прогнозов" as UC3
  usecase "Сохранить результат прогноза" as UC4

  usecase "Загрузить данные для обучения" as UC5
  usecase "Обучить модель" as UC6
  usecase "Обновить модель в системе" as UC7
  usecase "Мониторинг качества прогнозов" as UC8

}

User --> UC1
User --> UC2
User --> UC3

UC2 .> UC1 : <<include>>
UC4 .> UC2 : <<extend>>

Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8

@enduml