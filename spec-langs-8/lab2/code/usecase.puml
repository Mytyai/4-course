@startuml
left to right direction
title Диаграмма вариантов использования\n"Система прогнозирования цен на авиабилеты"

actor "Пользователь" as User

rectangle "Система прогнозирования цен на авиабилеты" {

  usecase "Авторизация" as UC1
  usecase "Ввести параметры перелёта" as UC2
  usecase "Получить прогноз цены" as UC3
  usecase "Просмотреть историю прогнозов" as UC4
  usecase "Проверить данные" as UC5
  usecase "Подготовить данные" as UC6
  usecase "Выполнить прогноз\n(ML модель)" as UC7
  usecase "Сохранить результат" as UC8

}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

UC3 .> UC2 : <<include>>
UC3 .> UC5 : <<include>>
UC3 .> UC6 : <<include>>
UC3 .> UC7 : <<include>>
UC3 .> UC8 : <<include>>

@enduml