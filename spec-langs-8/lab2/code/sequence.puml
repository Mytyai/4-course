@startuml
title Диаграмма последовательности\n"Получение прогноза цены"

actor "Пользователь" as User
participant "Интерфейс" as UI
participant "ForecastController" as Controller
participant "ForecastService" as Service
participant "DataProcessor" as Processor
participant "ML Модель" as Model
participant "Хранилище истории" as Storage

User -> UI : Ввод данных
UI -> Controller : sendRequest(request)
Controller -> Service : predict_price(request)

Service -> Service : validate(request)

alt Данные некорректны
  Service --> Controller : ошибка
  Controller --> UI : сообщение об ошибке
  UI --> User : показать ошибку
else Данные корректны
  Service -> Processor : prepare_data(request)
  Processor --> Service : features

  Service -> Model : predict(features)
  Model --> Service : price

  Service -> Storage : save(result)
  Storage --> Service : saved

  Service --> Controller : PredictionResult
  Controller --> UI : результат
  UI --> User : отображение прогноза
end

@enduml